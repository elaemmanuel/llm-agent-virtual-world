# backend/.env.example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (add to .gitignore)

# ===== APP SETTINGS =====
APP_NAME=LLM Agent in Virtual World
APP_VERSION=0.1.0
DEBUG=True

# ===== SERVER SETTINGS =====
HOST=0.0.0.0
PORT=8000
RELOAD=True

# ===== DATABASE SETTINGS =====
# PostgreSQL connection - update with your credentials
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/llm_agent_dev
DB_ECHO=False
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=0

# ===== LLM SETTINGS =====
# Get your API key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_MODEL=claude-opus-4-6

# ===== AGENT SETTINGS =====
AGENT_TIMEOUT=30
AGENT_MAX_STEPS=100
AGENT_TEMPERATURE=0.7

# ===== ENVIRONMENT SETTINGS =====
WORLD_SIZE_X=20
WORLD_SIZE_Y=20
WORLD_SIZE_Z=10

# ===== LOGGING SETTINGS =====
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===== CORS SETTINGS =====
# Frontend URLs that can call the API
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ===== WEBSOCKET SETTINGS =====
WEBSOCKET_TIMEOUT=60
MAX_CONCURRENT_CONNECTIONS=100